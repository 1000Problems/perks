# Supabase project credentials
# Find these in your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only key (do not expose to browser). Reserve for admin operations.
# SUPABASE_SERVICE_ROLE_KEY=

# Domain used to shape "account name" entries into email addresses for
# Supabase auth. Defaults to perks.1000problems.com. Override only if
# you're deploying under a different domain.
# NEXT_PUBLIC_AUTH_DOMAIN=perks.1000problems.com
