{
  "name": "perks",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "predev": "npm run cards:build",
    "build": "next build",
    "prebuild": "npm run cards:build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "cards:build": "tsx scripts/build-card-db.ts",
    "cards:check-sources": "tsx scripts/check-sources.ts",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "db:migrate-status": "tsx scripts/db-migrate.ts -- --status",
    "db:migrate-reset": "tsx scripts/db-migrate.ts -- --reset",
    "db:migrate-cards": "tsx scripts/migrate-cards-to-db.ts",
    "db:migrate-cards:dry-run": "tsx scripts/migrate-cards-to-db.ts -- --dry-run",
    "db:migrate-cards:report": "tsx scripts/migrate-cards-to-db.ts -- --report",
    "db:backfill-user-cards": "tsx scripts/backfill-user-cards-from-jsonb.ts",
    "db:backfill-user-signals": "tsx scripts/backfill-user-signals.ts",
    "db:verify-user-cards": "tsx scripts/verify-cards-held-parity.ts",
    "db:verify-cards-soul": "tsx scripts/verify-cards-soul-parity.ts",
    "cards:soul-status": "tsx scripts/soul-status.ts",
    "images:seed-synthetic": "tsx scripts/seed-synthetic-images.ts",
    "images:process": "tsx scripts/process-image.ts",
    "pretest": "npm run cards:build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "clsx": "^2.1.1",
    "next": "15.5.15",
    "postgres": "^3.4.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/runner": "^4.1.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-config-next": "15.5.15",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  }
}
